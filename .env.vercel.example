# ─────────────────────────────────────────────────────────────────
# ProStep — Vercel Environment Variables Reference
# Copy these into: Vercel Dashboard → Project → Settings → Environment Variables
# Set each variable for: Production, Preview, Development as needed
# ─────────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────────
# Use a connection pooler URL (e.g. Supabase pgBouncer / Neon pooled)
# for serverless — avoids "too many connections" on Vercel.
DATABASE_URL="postgresql://user:password@db.xxx.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct (non-pooled) URL — used by Prisma Migrate only (not needed on Vercel)
# DIRECT_URL="postgresql://user:password@db.xxx.supabase.co:5432/postgres"

# ── NEXT AUTH ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-32+-char-random-string"

# Must match your Vercel deployment URL exactly (no trailing slash)
# For preview deployments use VERCEL_URL automatically via the wrapper below
NEXTAUTH_URL="https://your-app.vercel.app"

# ── GOOGLE OAUTH (optional) ───────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── OPENAI ────────────────────────────────────────────────────────
# Used for AI learning path generation (/api/ai)
OPENAI_API_KEY="sk-..."

# ── MUX (video hosting) ───────────────────────────────────────────
# Create at: https://dashboard.mux.com → Settings → Access Tokens
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""

# ── EMAIL (Resend) ────────────────────────────────────────────────
# Create at: https://resend.com → API Keys
RESEND_API_KEY=""
FROM_EMAIL="noreply@yourdomain.com"

# ── APP PUBLIC VARS ───────────────────────────────────────────────
# These are exposed to the browser — do NOT put secrets here
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_NAME="ProStep"

# ─────────────────────────────────────────────────────────────────
# HOW TO ADD TO VERCEL (CLI):
#
#   npx vercel env add DATABASE_URL production
#   npx vercel env add NEXTAUTH_SECRET production
#   npx vercel env add NEXTAUTH_URL production
#   npx vercel env add OPENAI_API_KEY production
#   npx vercel env add MUX_TOKEN_ID production
#   npx vercel env add MUX_TOKEN_SECRET production
#   npx vercel env add NEXT_PUBLIC_APP_URL production
#
# Or bulk-import via Vercel Dashboard → Settings → Environment Variables → Import .env
# ─────────────────────────────────────────────────────────────────
